--- !u!114 &1186059095
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1186059093}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 8c368f377362b4a4e8589d5397a08eac, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  missionObjectiveUI: {fileID: 1810583843}
  narrationSystem: {fileID: 1658172359}
  objectives:
  - objectiveText: 'MOVEMENT SYSTEMS ONLINE

      Use the designated controls to
      move through the training area.'
    dialogue:
      speakerName: MISSION DIRECTOR
      subtitleText: Android Technicians must maintain mobility in unpredictable environments.
        Complete the mini-obstacle course.
      subtitleDuration: 0
      audioClip: {fileID: 8300000, guid: 195225fe00ac16b43ad375e4210bf062, type: 3}
  - objectiveText: 'MOVE THE ORANGE OBJECT

'
    dialogue:
      speakerName: MISSION DIRECTOR
      subtitleText: Orange objects can be manipulated. Move the obstruction and clear
        a path forward.
      subtitleDuration: 1
      audioClip: {fileID: 8300000, guid: 122d7d49cfcce224eb2953918b86dea4, type: 3}
  - objectiveText: COLLECT A CODE CLUE AND OPEN INVENTORY
    dialogue:
      speakerName: MISSION DIRECTOR
      subtitleText: Reconnaissance units are responsible for collecting mission-critical
        data. Approach the highlighted code fragment and collect it. Retrieved clues
        are automatically stored within your mission inventory for later analysis.
      subtitleDuration: 2
      audioClip: {fileID: 8300000, guid: e08d74c1f3286c14890c30f77a6fe635, type: 3}
  - objectiveText: TEST FUNCTIONALITY OF LIGHT ORB
    dialogue:
      speakerName: MISSION DIRECTOR
      subtitleText: 'The light orb in your chest cavity,  regulates environmental
        illumination and energy stabilization.

        Warning: prolonged usage
        will deplete internal charge reserves.'
      subtitleDuration: 3
      audioClip: {fileID: 8300000, guid: 5912a405c03386d4bb60640df5669bd0, type: 3}
  - objectiveText: ENTER THE PORTAL AND INITIALIZE TELEPORTATION
    dialogue:
      speakerName: MISSION DIRECTOR
      subtitleText: Training objectives complete. Proceed to the teleportation portal
        and initialize transfer to Domain X8. Stand within the transfer zone and
        press the Enter key to begin deployment.
      subtitleDuration: 3
      audioClip: {fileID: 8300000, guid: e75f9124aa68b3749bd58f86eb47d175, type: 3}
